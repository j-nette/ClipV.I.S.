# ---- Azure AI Foundry (fill in when you have access) ----
# If these are blank, the server runs in MOCK mode (keyword parser) so you can demo today.
FOUNDRY_ENDPOINT=
FOUNDRY_API_KEY=
FOUNDRY_DEPLOYMENT=

# ---- Azure Speech (TTS) ----
# If blank, the frontend falls back to the browser's built-in speech synthesis.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_SPEECH_VOICE=en-US-AndrewMultilingualNeural

# ---- Microsoft Fabric (SQL analytics endpoint) ----
# Server = the Lakehouse SQL endpoint host. Database = the Lakehouse name.
# If blank, the server uses the local mock metadata in models.js.
# Auth uses azure-active-directory-default: run `az login` first (and `az account set` to the right tenant).
FABRIC_SQL_SERVER=
FABRIC_SQL_DATABASE=clipvis

# ---- Server ----
PORT=3000
